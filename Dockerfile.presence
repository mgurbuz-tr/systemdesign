# syntax=docker/dockerfile:1.7
# Tiny WebSocket relay container — single dep (`ws`).
FROM node:20-alpine
WORKDIR /app
COPY server/package.json ./
RUN npm install --omit=dev --no-package-lock --silent && \
    npm cache clean --force
COPY server/presence-server.mjs ./
EXPOSE 3001
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget -q -O - http://127.0.0.1:3001/healthz || exit 1
CMD ["node", "presence-server.mjs"]
